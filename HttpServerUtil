  //get请求
    public void sendDataGetService(final String url, final NetWorkCallbackInterface dataCallBack, final NetWorkCallbackInterface failCallBack, final NetWorkCallbackInterface codeCallBack) {
        long timestamp = System.currentTimeMillis();
        JSONObject jsonObject = null;
        try {
            jsonObject = new JSONObject();
            jsonObject.put("appKey", HttpServerUtil.appKey);
            jsonObject.put("salt", HttpServerUtil.salt);
            jsonObject.put("version", getVersion());
            jsonObject.put("timestamp", "" + timestamp);
            jsonObject.put("extra", getExtraInfo());
            jsonObject.put("bizContent", "");
        } catch (JSONException e) {
            e.printStackTrace();
        }
        String sign = gateWaySign(jsonObject);

        OkHttpClient okHttpClient = new OkHttpClient();
        Request request = new Request
                .Builder()
                .get()
                .header("appKey", HttpServerUtil.appKey)
                .header("sign", sign)
                .header("jpush", MyApplication.getInstance().registrationID)
                .header("version", getVersion())
                .header("timestamp", "" + timestamp)
                .header("extra", getExtraInfo())
                .header("Authorization", getParamWithKey(TOKEN))
                .url(url)
                .build();

        okHttpClient.newCall(request).enqueue(new Callback() {
            @Override
            public void onFailure(@NonNull Call call, @NonNull IOException e) {
                if (failCallBack != null) {
                    failCallBack.showCallback("与服务器失去联系");
                }
                DebugModel.getInstance().systemPrint(url + "---" + "与服务器失去联系");

            }

            @Override
            public void onResponse(@NonNull Call call, @NonNull final Response response) throws IOException {
                final String result = Objects.requireNonNull(response.body()).string();
                try {
                    JSONObject object = new JSONObject(result);
                    if (isOperationForUrl(url)) {
                        if (object.getInt("code") == 401) {
                            if (codeCallBack != null) {
                                codeCallBack.showCallback(object.toString());
                            }
                        } else {
                            if (dataCallBack != null) {
                                dataCallBack.showCallback(result);
                            }
                        }
                        return;
                    }

                    if (object.getInt("code") == 200) {
                        String Content = object.get("data").toString();
                        int flag = object.optInt("flag",0);
                        if ((flag & (1 << 4) ) > 0) { //需要密钥解密
                            // 如果 flag 的第5位是1，则执行这里的代码
                            Content = AESUtils.decryptWithKeyIv(Content, secretKey, iv);
                        }
                        if (dataCallBack != null) {
                            dataCallBack.showCallback(Content);
                        }
                    } else {
                        if (codeCallBack != null) {
                            codeCallBack.showCallback(object.toString());
                        }
                    }
                } catch (Exception e) {
                    if (failCallBack != null) {
                        failCallBack.showCallback("解析数据错误");
                    }
                    DebugModel.getInstance().systemPrint(url + "---" + "解析数据错误");
                    e.printStackTrace();
                }
            }
        });
    }

