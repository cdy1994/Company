    //下载专用
    public void sendPostDownServer(String url, String json, String fileName, final NetWorkCallbackInterface netWorkCallbackInter,final NetWorkCallbackInterface failCallBack) {
        try {
            String bizContent = json;
            if (json == null) {
                bizContent = "";
            }
            OkHttpClient okHttpClient = new OkHttpClient();
            Request request = new Request
                    .Builder()
                    .url(url)
                    .build();
            okHttpClient.newCall(request).enqueue(new Callback() {
                @Override
                public void onResponse(@NonNull okhttp3.Call call, @NonNull Response response) throws IOException {
                    try {
                        String tempTimeEnd = TimeFormatUtils.getCurrentDate(2);
                        DebugModel.getInstance().addTextInMap( request + "--download");
                        // 获取响应数据
                        ResponseBody body = response.body();
                        // 将响应数据保存为PDF文件
                        InputStream inputStream = body.byteStream();
                        String mPath = BaseUtil.getXlsFileName(fileName);
                        File pdfFile = new File(mPath);
                        FileOutputStream outputStream = new FileOutputStream(pdfFile);
                        byte[] buffer = new byte[4096];
                        int bytesRead;
                        while ((bytesRead = inputStream.read(buffer)) != -1) {
                            outputStream.write(buffer, 0, bytesRead);
                        }
                        outputStream.flush();
                        outputStream.close();
                        inputStream.close();

                        if (netWorkCallbackInter != null) {
                            netWorkCallbackInter.showCallback(pdfFile.getPath());
                        }
                    } catch (Exception e) {
                        if (netWorkCallbackInter != null) {
                            netWorkCallbackInter.showCallback("");
                        }
                    }
                }

                @Override
                public void onFailure(@NonNull okhttp3.Call call, @NonNull IOException e) {
                    failCallBack.showCallback("与服务器失去联系");
                    DebugModel.getInstance().systemPrint(url + "/" + json + "---" + "与服务器失去联系");
                }
            });
        } catch (Exception e) {
            e.printStackTrace();
        }
    }


    public void uploadFile(final NetWorkCallbackInterface dataCallBack, final NetWorkCallbackInterface failCallBack, final NetWorkCallbackInterface codeCallBack, String uploadUrl, String key, String token, File file) {
        MultipartBody builder = new MultipartBody.Builder()
                .setType(MultipartBody.FORM)
                .addFormDataPart("key", key)
                .addFormDataPart("token", token)
                .addFormDataPart("file", file.getName(), RequestBody.create(MediaType.parse("multipart/form-data"), file))
                .build();

        final String printString = uploadUrl + "?file=" + file.getName() + "&key=" + key + "&token=" + token;
        OkHttpClient okHttpClient = new OkHttpClient.Builder()
                .connectTimeout(60, TimeUnit.SECONDS)
                .writeTimeout(60, TimeUnit.SECONDS)
                .readTimeout(60, TimeUnit.SECONDS)
                .build();
        Request request = new Request.Builder()
                .url(uploadUrl)//地址
                .post(builder)//添加请求体
                .header("Authorization", getParamWithKey(TOKEN))
                .build();

        okHttpClient.newCall(request).enqueue(new Callback() {
            @Override
            public void onResponse(@NonNull okhttp3.Call call, @NonNull Response response) throws IOException {
                //此方法运行在子线程中，不能在此方法中进行UI操作。
                final String result = response.body().string();
                dataCallBack.showCallback(uploadUrl + "/" + key);
            }

            @Override
            public void onFailure(@NonNull okhttp3.Call call, @NonNull IOException e) {
                failCallBack.showCallback("与服务器失去联系");
                DebugModel.getInstance().systemPrint(uploadUrl + "/" + key + "---" + "与服务器失去联系");
            }
        });
    }

